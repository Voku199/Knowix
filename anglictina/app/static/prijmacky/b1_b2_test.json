    {
      "type": "grammar",
      "title": "Grammar & Use of English",
      "questions": [
        {
          "id": "b1-g-1",
          "format": "mcq",
          "prompt": "I ___ never been to London.",
          "options": [
            "have",
            "has",
            "had",
            "having"
          ],
          "correct": [
            "have"
          ],
          "explanation": "Present perfect."
        },
        {
          "id": "b1-g-2",
          "format": "mcq",
          "prompt": "If I ___ more time, I would travel more.",
          "options": [
            "have",
            "had",
            "has",
            "having"
          ],
          "correct": [
            "had"
          ],
          "explanation": "Second conditional."
        },
        {
          "id": "b1-g-3",
          "format": "mcq",
          "prompt": "She suggested ___ by train.",
          "options": [
            "go",
            "going",
            "to go",
            "gone"
          ],
          "correct": [
            "going"
          ],
          "explanation": "Suggest + -ing."
        },
        {
          "id": "b1-g-4",
          "format": "mcq",
          "prompt": "By the time we arrived, the film ___.",
          "options": [
            "started",
            "had started",
            "starts",
            "has started"
          ],
          "correct": [
            "had started"
          ],
          "explanation": "Past perfect."
        },
        {
          "id": "b1-g-5",
          "format": "mcq",
          "prompt": "You ___ smoke here. It's forbidden.",
          "options": [
            "must",
            "mustn't",
            "don't have to",
            "should"
          ],
          "correct": [
            "mustn't"
          ],
          "explanation": "Prohibition."
        },
        {
          "id": "b1-g-6",
          "format": "mcq",
          "prompt": "I wish I ___ taller.",
          "options": [
            "am",
            "was",
            "were",
            "will be"
          ],
          "correct": [
            "were"
          ],
          "explanation": "Wish + past (were)."
        },
        {
          "id": "b1-g-7",
          "format": "mcq",
          "prompt": "He said he ___ help me later.",
          "options": [
            "will",
            "would",
            "can",
            "must"
          ],
          "correct": [
            "would"
          ],
          "explanation": "Reported speech."
        },
        {
          "id": "b1-g-8",
          "format": "mcq",
          "prompt": "Neither Tom nor Jane ___ coming.",
          "options": [
            "is",
            "are",
            "were",
            "be"
          ],
          "correct": [
            "is"
          ],
          "explanation": "Neither...nor agreement."
        },
        {
          "id": "b1-g-9",
          "format": "mcq",
          "prompt": "I look forward to ___ from you.",
          "options": [
            "hear",
            "hearing",
            "to hear",
            "heard"
          ],
          "correct": [
            "hearing"
          ],
          "explanation": "look forward to + -ing."
        },
        {
          "id": "b1-g-10",
          "format": "mcq",
          "prompt": "This is the person ___ car was stolen.",
          "options": [
            "who",
            "which",
            "whose",
            "whom"
          ],
          "correct": [
            "whose"
          ],
          "explanation": "Possessive relative."
        }
      ]
    },
